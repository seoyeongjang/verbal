{
  "name": "verbal-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "tsc",
    "test:calendar-parser": "npm run build && node scripts/calendar-parser-test.js",
    "test:plugin-platform": "npm run build && node scripts/plugin-platform-test.js",
    "plugin:key-doc": "node scripts/create-plugin-api-key.js",
    "prepare:play-store-assets": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\generate-play-store-assets.ps1",
    "prepare:play-console-pack": "node scripts/generate-play-console-pack.js",
    "prepare:app-content-answers": "node scripts/generate-app-content-answers.js",
    "prepare:app-content-copy-sheet": "node scripts/generate-app-content-copy-sheet.js",
    "prepare:closed-testing-pack": "node scripts/generate-closed-testing-pack.js",
    "prepare:launch-handoff": "node scripts/generate-launch-handoff.js",
    "guide:next-launch-step": "node scripts/generate-next-external-step-guide.js",
    "open:next-launch-step": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\open-play-console-next-step.ps1",
    "prepare:launch-evidence": "node scripts/prepare-launch-evidence-template.js",
    "record:launch-evidence": "node scripts/record-launch-evidence.js",
    "record:app-content-submitted": "node scripts/record-app-content-submitted.js",
    "record:prelaunch-reviewed": "node scripts/record-prelaunch-reviewed.js",
    "record:closed-testing-completed": "node scripts/record-closed-testing-completed.js",
    "record:closed-testing-not-required": "node scripts/record-closed-testing-not-required.js",
    "record:real-device-e2e": "node scripts/record-real-device-e2e.js",
    "record:fcm-real-device": "node scripts/record-fcm-real-device.js",
    "report:launch-gate": "node scripts/generate-launch-gate-report.js",
    "status:launch": "node scripts/generate-launch-status.js",
    "firebase": "node scripts/firebase-cli.js",
    "local:stt": "node scripts/local-stt-server.js",
    "serve": "npm run build && node scripts/firebase-cli.js emulators:start --only functions,firestore,storage,auth",
    "emulators:check": "node scripts/firebase-cli.js emulators:exec --project demo-verbal --only firestore,storage \"cmd /c echo rules-ok\"",
    "rules:test": "node scripts/firebase-cli.js emulators:exec --project demo-verbal --only firestore,storage \"node functions/scripts/security-rules-test.js\"",
    "smoke:prod-e2e": "node scripts/production-e2e-smoke.js",
    "verify:android-release": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\verify-android-release-artifact.ps1",
    "verify:audio-retention": "node scripts/firebase-cli.js emulators:exec --project demo-verbal --only firestore,storage \"node functions/scripts/verify-audio-retention.js\"",
    "verify:audio-retention:prod": "node scripts/verify-audio-retention.js --prod",
    "verify:deepgram-streaming": "node scripts/verify-deepgram-streaming-token.js",
    "verify:hosted-policy-urls": "node scripts/verify-hosted-policy-urls.js",
    "verify:android-device-precheck": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\run-android-real-device-precheck.ps1",
    "verify:fcm-real-device": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\run-fcm-real-device-qa.ps1",
    "verify:launch-consistency": "node scripts/verify-launch-consistency.js",
    "verify:launch-evidence": "node scripts/verify-launch-evidence.js",
    "verify:launch-readiness": "node scripts/verify-launch-readiness.js",
    "verify:public-release": "node scripts/verify-public-release-gate.js",
    "verify:public-release-gate": "npm run verify:public-release",
    "verify:preinternal": "node scripts/run-preinternal-release-check.js",
    "deploy": "node scripts/firebase-cli.js deploy --only functions,firestore:rules,firestore:indexes,storage",
    "deploy:firestore": "node scripts/firebase-cli.js deploy --only firestore:rules,firestore:indexes --project voice-messenger-jangs-260522",
    "deploy:storage": "node scripts/firebase-cli.js deploy --only storage --project voice-messenger-jangs-260522",
    "deploy:functions": "node scripts/firebase-cli.js deploy --only functions --project voice-messenger-jangs-260522"
  },
  "dependencies": {
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "google-auth-library": "^10.6.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.13.0",
    "firebase-tools": "^15.18.0",
    "picomatch": "^4.0.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/storage@7.19.0": {
      "uuid": "^11.1.1",
      "google-auth-library": "^10.6.2"
    },
    "firebase-tools": {
      "universal-analytics": {
        "uuid": "^14.0.0"
      },
      "uuid": "^11.1.1"
    },
    "gaxios": "^7.1.4",
    "google-gax": "^5.0.6",
    "teeny-request": "^10.1.2"
  }
}
