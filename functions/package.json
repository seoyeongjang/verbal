{
  "name": "verbal-functions",
  "private": true,
  "main": "lib/index.js",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "build": "tsc",
    "test:calendar-parser": "npm run build && node scripts/calendar-parser-test.js",
    "firebase": "node scripts/firebase-cli.js",
    "local:stt": "node scripts/local-stt-server.js",
    "serve": "npm run build && node scripts/firebase-cli.js emulators:start --only functions,firestore,storage,auth",
    "emulators:check": "node scripts/firebase-cli.js emulators:exec --project demo-verbal --only firestore,storage \"cmd /c echo rules-ok\"",
    "rules:test": "node scripts/firebase-cli.js emulators:exec --project demo-verbal --only firestore,storage \"node functions/scripts/security-rules-test.js\"",
    "smoke:prod-e2e": "node scripts/production-e2e-smoke.js",
    "verify:deepgram-streaming": "node scripts/verify-deepgram-streaming-token.js",
    "deploy": "node scripts/firebase-cli.js deploy --only functions,firestore:rules,firestore:indexes,storage",
    "deploy:firestore": "node scripts/firebase-cli.js deploy --only firestore:rules,firestore:indexes --project voice-messenger-jangs-260522",
    "deploy:storage": "node scripts/firebase-cli.js deploy --only storage --project voice-messenger-jangs-260522",
    "deploy:functions": "node scripts/firebase-cli.js deploy --only functions --project voice-messenger-jangs-260522"
  },
  "dependencies": {
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "google-auth-library": "^10.6.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "firebase": "^12.13.0",
    "firebase-tools": "^15.18.0",
    "picomatch": "^4.0.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@google-cloud/firestore": "^8.6.0",
    "@google-cloud/storage@7.19.0": {
      "uuid": "^11.1.1",
      "google-auth-library": "^10.6.2"
    },
    "firebase-tools": {
      "universal-analytics": {
        "uuid": "^14.0.0"
      },
      "uuid": "^11.1.1"
    },
    "gaxios": "^7.1.4",
    "google-gax": "^5.0.6",
    "teeny-request": "^10.1.2"
  }
}
